generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Product {
  id          String   @id @default(uuid())
  name        String
  description String
  thumbnail   String   
  price       Int      
  isFeatured  Boolean  @default(false)
  isActive    Boolean  @default(true) 
  clicks      Int      @default(0)
  badge       String? 
  
  // ─── CHANGED: We removed the hardcoded string and replaced it with a relation ───
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id])
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("products")
}

// ─── NEW: The Category Model ───
model Category {
  id          String    @id @default(uuid())
  name        String    @unique // e.g. "Cakes", "Pastries"
  slug        String    @unique // e.g. "cakes", "pastries" (Great for URLs later!)
  
  // This tells Prisma that one category can have many products
  products    Product[] 

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("categories")
}

model StoreSettings {
  id             String   @id @default("default")
  whatsappNumber String   @default("6285121118121")
  instagramUrl   String?
  tiktokUrl      String?
  updatedAt      DateTime @updatedAt
}